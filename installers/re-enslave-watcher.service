[Unit]
Description=FocusLock re-enslave watcher (auto-sideload phones when they come online)
Documentation=https://github.com/anthropics/claude-code
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Points at ~/.local/bin/re-enslave-watcher (a symlink installed by
# re-enslave-all.sh --install-watcher). systemd's ExecStart parser rejects
# paths containing apostrophes, so we can't reference the canonical script
# at "…/Lion's Share + Bunny Tasker/installers/…" directly — the symlink
# is our escape hatch.
ExecStart=%h/.local/bin/re-enslave-watcher
# Drop privileges, no new ones (the script only does ADB + filesystem ops)
NoNewPrivileges=yes
# Tighten filesystem access — the script writes only its state file
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/state/focuslock %t
# Allow stdout to flow to the journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=re-enslave-watcher

[Install]
WantedBy=default.target
