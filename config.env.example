# FocusLock Server Configuration
# Copy to config.env and edit. Used by systemd services via EnvironmentFile.

# ── Required ──
FOCUSLOCK_PIN=changeme              # Mesh authentication PIN

# ── Homelab (optional — leave blank for P2P-only) ──
FOCUSLOCK_HOMELAB=                  # e.g. http://192.168.1.100:8434
FOCUSLOCK_URL=                      # e.g. https://your-domain.com (HTTPS proxy to homelab)

# ── Mail Service (optional — requires homelab) ──
MAIL_HOST=                          # IMAP host for payment detection
SMTP_HOST=                          # SMTP host for evidence emails
MAIL_USER=                          # IMAP/SMTP username
MAIL_PASS=                          # IMAP/SMTP password
PARTNER_EMAIL=                      # Lion's email for evidence notifications

# ── Phone (optional — for bridge ADB enforcement) ──
PHONE_URL=                          # e.g. http://192.168.1.50:8432

# ── Ports (defaults are fine for most setups) ──
FOCUSLOCK_PHONE_PORT=8432
FOCUSLOCK_HOMELAB_PORT=8434
FOCUSLOCK_MESH_PORT=8435
