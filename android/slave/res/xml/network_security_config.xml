<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext needed for LAN peer communication (gossip, ADB bridge).
         Relay URL security enforced in code: meshSync/vaultSync require HTTPS for non-LAN URLs. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
